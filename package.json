{
  "name": "memocall",
  "version": "0.1.0",
  "mcpName": "io.github.baodq06/memocall",
  "description": "An MCP server that recalls past Claude Code conversations across all projects as clean, compact Markdown.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baodq06/memocall.git"
  },
  "homepage": "https://github.com/baodq06/memocall#readme",
  "bin": {
    "memocall": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke": "npm run build && node test/smoke-corpus.mjs",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "parse": "npm run build && node dist/parser.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "model-context-protocol",
    "session",
    "context"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
